    "pino": "^10.3.1",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^11.0.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.74.0",
