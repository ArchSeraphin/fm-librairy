    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@tanstack/react-query": "^5.100.5",
    "@trpc/client": "^11.13.0",
    "@trpc/next": "^11.13.0",
    "@trpc/react-query": "^11.13.0",
    "@trpc/server": "^11.13.0",
    "bullmq": "^5.76.2",
    "clamscan": "^2.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
